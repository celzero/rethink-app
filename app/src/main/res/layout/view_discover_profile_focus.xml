<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/fdp_focus_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_firewall_shield" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/fdp_focus_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="39dp"
        android:text="@string/power_profile_focus_title"
        android:textColor="?attr/primaryTextColor"
        android:textSize="16sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/fdp_focus_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/fdp_focus_title"
        android:layout_marginStart="39dp"
        android:layout_marginTop="4dp"
        android:layout_toStartOf="@id/fdp_focus_arrow"
        android:text="@string/power_profile_focus_desc"
        android:textColor="?attr/secondaryTextColor"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/fdp_focus_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/fdp_focus_title"
        android:layout_marginStart="39dp"
        android:layout_marginTop="56dp"
        android:text="@string/power_profile_focus_meta"
        android:textColor="?attr/secondaryTextColor"
        android:textSize="13sp" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/fdp_focus_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_right_arrow_white" />
</RelativeLayout>
