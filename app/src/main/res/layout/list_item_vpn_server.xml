<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/server_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:minHeight="64dp"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_flag"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="26sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="🇺🇸" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_flag_image"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="5dp"
        android:src="@drawable/ic_rpn_auto_2"
        android:tint="?attr/primaryTextColor"
        android:alpha="0.8"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/country_info_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/stats_layout"
        app:layout_constraintEnd_toStartOf="@id/info_icon"
        app:layout_constraintStart_toEndOf="@id/tv_flag"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_country_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="?attr/primaryTextColor"
                android:textSize="15sp"
                tools:text="United States" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/latency_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:alpha="0.6"
                android:fontFamily="sans-serif-medium"
                android:textSize="11sp"
                tools:text="1.0 Gbps · 20%"
                tools:textColor="?attr/chipTextPositive" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_server_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:layout_gravity="center"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="12sp"
                android:alpha="0.85"
                tools:visibility="visible"
                android:visibility="gone"
                tools:text="100.82.27.93" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_uptime_sep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_gravity="center"
                android:layout_marginEnd="5dp"
                android:text="@string/lbl_separator_dot"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="11sp"
                android:visibility="visible" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_uptime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:textSize="12sp"
                android:alpha="0.85"
                android:layout_gravity="center"
                android:textColor="?attr/primaryLightColorText"
                tools:visibility="visible"
                android:visibility="gone"
                tools:text="2 min ago" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/stats_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBaseline_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/country_info_layout">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_server_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="?attr/accentGood"
                android:textSize="11sp"
                tools:text="Active" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_status_sep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:text="@string/lbl_separator_dot"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="11sp"
                tools:visibility="visible"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_apps_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="11sp"
                android:visibility="visible"
                tools:text="3 apps" />
        </LinearLayout>

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/info_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="6dp"
        android:src="@drawable/ic_cross"
        android:tint="?attr/primaryLightColorText"
        android:contentDescription="@string/lbl_remove"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:layout_marginStart="48dp"
        android:alpha="0.15"
        android:background="?attr/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
