<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="top">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/ic_circle"
            android:backgroundTint="?attr/chipBgColorPositive">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_type_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                tools:src="@drawable/ic_rethink_plus"
                tools:tint="?attr/accentGood" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_product_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/large_font_text_view"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/primaryTextColor"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Standard • Monthly" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="@dimen/default_font_text_view"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/rectangle_border_background"
                    android:backgroundTint="?attr/chipBgColorPositive"
                    android:textColor="?attr/chipTextPositive"
                    tools:text="SUBS" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_type_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="@dimen/small_font_subheading_text"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/rectangle_border_background"
                    android:backgroundTint="?attr/chipBgColorPositive"
                    android:textColor="?attr/primaryTextColor"
                    tools:text="Active" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_test_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    tools:text="TEST"
                    android:textSize="@dimen/small_font_subheading_text"
                    android:textStyle="bold"
                    android:textColor="?attr/accentBad"
                    android:background="@drawable/rectangle_border_background"
                    android:backgroundTint="?attr/chipBgColorNegative"
                    android:visibility="gone" />

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_date_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="@dimen/default_font_text_view"
                android:textColor="?attr/primaryLightColorText"
                tools:text="Jan 15, 2025  10:00 AM" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_date_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/default_font_text_view"
                android:textColor="?attr/primaryLightColorText"
                android:visibility="gone"
                tools:text="Expires Feb 15, 2025"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="?attr/primaryLightColorText"
                android:alpha="0.7"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                tools:text="Order: GPA.1234-5678-9012"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_token"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/small_font_subheading_text"
                android:fontFamily="monospace"
                android:textColor="?attr/primaryLightColorText"
                android:alpha="0.5"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Token: kgnknnfnkjdgaeop" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="55dp"
        android:background="?attr/border" />

</LinearLayout>

