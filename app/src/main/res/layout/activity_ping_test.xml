<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp"
                android:text="@string/ping_test_title"
                android:textColor="?attr/primaryTextColor"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Single merged card: status + input + button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/test_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Animated Icon + Progress Ring -->
                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_indicator"
                            android:layout_width="104dp"
                            android:layout_height="104dp"
                            android:layout_gravity="center"
                            android:indeterminate="true"
                            android:visibility="gone"
                            app:indicatorColor="?attr/accentGood"
                            app:indicatorSize="104dp"
                            app:trackColor="@android:color/transparent"
                            app:trackThickness="4dp" />

                        <ImageView
                            android:id="@+id/status_icon"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_check"
                            android:contentDescription="@string/ping_test_title"
                            app:tint="?attr/primaryTextColor" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/status_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ping_ready_title"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/status_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/ping_ready_desc"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <!-- Latency badge -->
                    <LinearLayout
                        android:id="@+id/latency_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_card_ripple">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_timer"
                            android:contentDescription="@string/lbl_status"
                            app:tint="?attr/accentGood" />

                        <TextView
                            android:id="@+id/latency_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:textColor="?attr/accentGood"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="320ms" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="?attr/divider" />

                    <!-- Domain/IP input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/reach_input_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/ping_reach_hint"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/reach_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:imeOptions="actionDone"
                            android:singleLine="true"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Run Test button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ping_button"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/ping_test_button"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                        app:cornerRadius="26dp"
                        app:strokeColor="?attr/border" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Results Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/results_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/results_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="12dp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
