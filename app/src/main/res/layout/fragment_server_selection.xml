<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass"
        android:fitsSystemWindows="true"
        app:elevation="4dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:contentScrim="@drawable/bg_vpn_header_gradient"
            android:background="@drawable/bg_vpn_header_gradient"
            app:expandedTitleMarginBottom="0dp"
            app:expandedTitleMarginEnd="16dp"
            app:expandedTitleMarginStart="10dp"
            app:expandedTitleMarginTop="10dp"
            app:expandedTitleTextAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:titleEnabled="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                app:layout_collapseMode="parallax">

                <LinearLayout
                    android:id="@+id/status_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.95"
                    android:translationZ="2dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <LinearLayout
                            android:id="@+id/location_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="visible">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:gravity="center_vertical"
                                    android:layout_marginStart="-4dp"
                                    android:drawableTint="?attr/primaryTextColor"
                                    android:drawableStart="@drawable/ic_rethink_plus"
                                    android:text="@string/proxy_rpn_heading"
                                    android:textColor="?attr/homeScreenHeaderTextColor"
                                    android:textSize="@dimen/small_font_text_view" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tv_current_country"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:fontFamily="sans-serif-medium"
                                    android:maxLines="2"
                                    tools:text="Auto"
                                    android:textColor="?attr/homeScreenHeaderTextColor"
                                    android:textSize="@dimen/extra_large_font_text_view"
                                    android:textStyle="bold" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tv_current_location"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    tools:text="Automatic server selection"
                                    android:textColor="?attr/homeScreenHeaderTextColor"
                                    android:textSize="@dimen/default_font_text_view" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/status_chip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_vpn_status_chip"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="4dp">

                                <View
                                    android:id="@+id/status_indicator"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/ic_circle"
                                    android:backgroundTint="?attr/accentGood" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tv_connection_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/dns_connected"
                                    android:padding="2dp"
                                    android:textColor="?attr/accentGood"
                                    android:textSize="@dimen/small_font_text_view"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/hero_ip_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <LinearLayout
                                android:id="@+id/hero_ip_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                        </LinearLayout>

                        <com.facebook.shimmer.ShimmerFrameLayout
                            android:id="@+id/shimmer_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="visible"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            app:shimmer_auto_start="true"
                            app:shimmer_base_alpha="0.12"
                            app:shimmer_duration="1200"
                            app:shimmer_highlight_alpha="0.35">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <View
                                        android:layout_width="72dp"
                                        android:layout_height="10dp"
                                        android:alpha="0.6"
                                        android:background="@drawable/shimmer_placeholder" />

                                    <View
                                        android:layout_width="150dp"
                                        android:layout_height="20dp"
                                        android:layout_marginTop="8dp"
                                        android:background="@drawable/shimmer_placeholder" />

                                    <View
                                        android:layout_width="100dp"
                                        android:layout_height="12dp"
                                        android:layout_marginTop="6dp"
                                        android:alpha="0.7"
                                        android:background="@drawable/shimmer_placeholder" />

                                </LinearLayout>

                                <View
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:alpha="0.5"
                                    android:background="@drawable/shimmer_placeholder" />

                            </LinearLayout>

                        </com.facebook.shimmer.ShimmerFrameLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="12dp"
                            android:alpha="0.3"
                            android:background="?attr/primaryTextColor" />

                        <LinearLayout
                            android:id="@+id/subscription_banner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="5dp"
                            android:visibility="visible">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_expiry_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:textColor="?attr/homeScreenHeaderTextColor"
                                android:textSize="12sp" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_expiry_date"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/homeScreenHeaderTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_days_remaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:textColor="?attr/homeScreenHeaderTextColor"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="visible" />

                        </LinearLayout>

                        <com.facebook.shimmer.ShimmerFrameLayout
                            android:id="@+id/shimmer_subscription_banner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="14dp">

                                <View
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/shimmer_placeholder" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="14dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/shimmer_placeholder" />

                                <View
                                    android:layout_width="60dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/shimmer_placeholder" />

                            </LinearLayout>

                        </com.facebook.shimmer.ShimmerFrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="0dp"
                            android:gravity="center_vertical"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_hero_plan_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="?attr/homeScreenHeaderTextColor"
                                android:textSize="@dimen/small_font_text_view" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_hero_account_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:fontFamily="monospace"
                                android:textColor="?attr/homeScreenHeaderTextColor"
                                android:textSize="@dimen/small_font_text_view" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:title="" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/servers_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:layout_marginTop="10dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/search_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="8dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_search"
                            android:tint="?attr/primaryLightColorText" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/search_bar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/server_selection_search_hint"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="?attr/primaryTextColor"
                            android:textColorHint="?attr/primaryLightColorText"
                            android:textSize="@dimen/large_font_text_view" />

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/search_clear_btn"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/server_selection_clear_search"
                            android:src="@drawable/ic_cross"
                            android:tint="?attr/primaryLightColorText"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/support_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    app:backgroundTint="?attr/chipBgColorPositive"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="24dp"
                    app:iconTint="?attr/accentGood" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/settings_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="@string/server_settings_open"
                    app:backgroundTint="?attr/chipBgColorPositive"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_settings"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="24dp"
                    app:iconTint="?attr/accentGood" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/selected_servers_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_selected_servers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="4dp"
                    tools:listitem="@layout/list_item_vpn_server" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/frequent_countries_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="2dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_selection_frequent_label"
                    android:textColor="?attr/primaryLightColorText"
                    android:textSize="@dimen/small_font_text_view"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:fadingEdgeLength="20dp"
                    android:requiresFadingEdge="horizontal">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/frequent_chip_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="4dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="6dp"
                        app:chipSpacingHorizontal="6dp"
                        app:singleLine="true" />

                </HorizontalScrollView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/error_state_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="28dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/error_illustration"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_firewall_wifi_off"
                        android:tint="?attr/accentBad" />

                </FrameLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/error_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/server_selection_error_title"
                    android:textColor="?attr/primaryTextColor"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:maxWidth="300dp"
                    android:text="@string/server_selection_error_message"
                    android:textColor="?attr/primaryLightColorText"
                    android:textSize="@dimen/default_font_text_view" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/error_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:alpha="0.6"
                    android:gravity="center"
                    android:maxWidth="280dp"
                    android:text="@string/server_selection_error_hint"
                    android:textColor="?attr/primaryLightColorText"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/error_retry_btn"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:text="@string/server_selection_error_retry"
                    android:textSize="@dimen/large_font_text_view"
                    android:textStyle="bold"
                    app:cornerRadius="26dp"
                    app:elevation="4dp"
                    android:textColor="?attr/accentBad"
                    app:iconTint="?attr/accentBad"
                    app:icon="@drawable/ic_refresh"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/empty_selection_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_vpn"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/server_selection_tap_to_select"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="@dimen/large_font_text_view" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.7"
                        android:text="@string/server_selection_max_info"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="@dimen/small_font_subheading_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/server_count_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingTop="12dp"
                android:paddingEnd="24dp"
                android:paddingBottom="4dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_server_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/primaryTextColor"
                    android:textSize="@dimen/large_font_text_view"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_selection_max_info"
                    android:textColor="?attr/primaryLightColorText"
                    android:textSize="@dimen/small_font_text_view" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_servers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="4dp"
                android:paddingTop="0dp"
                android:paddingEnd="4dp"
                android:paddingBottom="12dp"
                android:visibility="gone"
                tools:listitem="@layout/list_item_country_card" />

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer_server_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:visibility="visible"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.10"
                app:shimmer_duration="1200"
                app:shimmer_highlight_alpha="0.30">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/list_item_shimmer_server_row" />

                    <include layout="@layout/list_item_shimmer_server_row" />

                    <include layout="@layout/list_item_shimmer_server_row" />

                    <include layout="@layout/list_item_shimmer_server_row" />

                    <include layout="@layout/list_item_shimmer_server_row" />

                </LinearLayout>

            </com.facebook.shimmer.ShimmerFrameLayout>

            <LinearLayout
                android:id="@+id/empty_state_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:alpha="0.5"
                    android:src="@drawable/illustrations_no_record"
                    android:tint="?attr/primaryLightColorText" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/server_selection_no_servers"
                    android:textColor="?attr/primaryTextColor"
                    android:textSize="@dimen/extra_large_font_text_view"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/server_selection_no_servers_desc"
                    android:textAlignment="center"
                    android:textColor="?attr/primaryLightColorText"
                    android:textSize="@dimen/default_font_text_view" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_stop_proxy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:contentDescription="@string/server_settings_stop_proxies"
        android:src="@drawable/ic_stop"
        android:visibility="gone"
        app:elevation="8dp"
        app:backgroundTint="?attr/colorError"
        app:tint="@android:color/white" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_start_proxy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/server_settings_start_rpn"
        android:textColor="@android:color/white"
        android:visibility="gone"
        app:elevation="8dp"
        app:icon="@drawable/ic_vpn"
        app:iconTint="@android:color/white"
        app:backgroundTint="@color/accentGood" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:indicatorColor="@android:color/white"
        app:indicatorSize="64dp"
        app:trackColor="?attr/primaryLightColorText"
        app:trackThickness="3dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
