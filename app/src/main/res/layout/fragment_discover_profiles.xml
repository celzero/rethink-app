<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="70dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="700dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="15dp"
                android:paddingTop="15dp"
                android:paddingEnd="15dp"
                android:paddingBottom="15dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@id/fdp_info_icon"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:text="@string/power_discover_profiles_title"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/fdp_info_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/power_info_button_content_description"
                        android:src="@drawable/ic_info" />
                </RelativeLayout>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_smooth_internet_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_smooth_internet" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_safe_beautiful_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_safe_beautiful" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_parental_control_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_parental_control" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_app_horse_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_app_horse" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_exam_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_exam" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_focus_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_focus" />
            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_discover_profiles_import_heading"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fdp_import_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_discover_profile_import" />
            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/fdp_imported_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_discover_profiles_imported_heading"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/fdp_imported_profiles_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
