<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="70dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="700dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="15dp"
                android:paddingTop="15dp"
                android:paddingEnd="15dp"
                android:paddingBottom="15dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fp_title"
                    style="@style/TextAppearance.Heading.HomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:text="@string/title_power" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fp_title_desc"
                    style="@style/TextAppearance.SubHeading.HomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/power_title_desc" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/fp_pause_icon"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_gravity="start"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="10dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/fp_dns_on_off_btn"
                        style="@style/Button.HomeScreen.Main"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_pause"
                        android:drawableEnd="@drawable/ic_arrow_down"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="@string/hsf_start_btn_state" />

                    <Button
                        android:id="@+id/fp_bottom_sheet_icon"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_gravity="end"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="10dp" />
                </FrameLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fp_status_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif-smallcaps"
                    android:textColor="?attr/accentBad"
                    android:textSize="@dimen/large_font_text_view" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_profiles_section"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_active_profiles_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_active_profiles" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_discover_profiles_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_discover_profiles" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_save_setup_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_save_setup" />
            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_controls_section"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_logs_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_logs" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_dashboard_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_dashboard" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
