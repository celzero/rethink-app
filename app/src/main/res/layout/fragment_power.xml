<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="70dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="700dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="15dp"
                android:paddingTop="15dp"
                android:paddingEnd="15dp"
                android:paddingBottom="15dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fp_title"
                    style="@style/TextAppearance.Heading.HomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:text="@string/title_power" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fp_title_desc"
                    style="@style/TextAppearance.SubHeading.HomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/power_title_desc" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/fp_status_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:src="@drawable/ic_firewall_shield" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/fp_status_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_toEndOf="@id/fp_status_icon"
                        android:text="@string/power_status_label"
                        android:textColor="?attr/secondaryTextColor"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/fp_status_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/fp_status_label"
                        android:layout_marginStart="15dp"
                        android:layout_marginTop="4dp"
                        android:layout_toEndOf="@id/fp_status_icon"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/fp_status_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/fp_status_value"
                        android:layout_marginStart="15dp"
                        android:layout_marginTop="4dp"
                        android:layout_toEndOf="@id/fp_status_icon"
                        android:textColor="?attr/secondaryTextColor"
                        android:textSize="14sp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_profiles_section"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_active_profiles_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_active_profiles" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_discover_profiles_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_discover_profiles" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_save_setup_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_save_setup" />
            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="8dp"
                android:text="@string/power_controls_section"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_logs_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_logs" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fp_dashboard_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <include layout="@layout/view_power_list_item_dashboard" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
