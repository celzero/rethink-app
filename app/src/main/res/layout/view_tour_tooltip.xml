<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tour_tooltip_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    app:cardBackgroundColor="?attr/tourTooltipBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/border"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/tour_premium_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_tour_premium_stripe"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_rethink_plus_sparkle"
                android:tint="?attr/colorGolden" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="@string/tour_premium_badge_label"
                android:textAllCaps="true"
                android:textColor="?attr/colorGolden"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Step counter chip: "1 of 5" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tour_step_counter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:alpha="0.55"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="?attr/primaryTextColor"
                android:textSize="11sp" />

            <!-- Close / dismiss button -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/tour_close_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/tour_btn_skip"
                android:padding="4dp"
                android:src="@drawable/ic_cross"
                android:tint="?attr/primaryLightColorText" />

        </LinearLayout>

        <!-- Title -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tour_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/primaryTextColor"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Description -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tour_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:textColor="?attr/primaryTextColor"
            android:textSize="13sp"
            android:alpha="0.8" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="2dp"
            android:alpha="0.15"
            android:background="?attr/primaryTextColor" />

        <!-- Action row: Skip (left) | Next / Got it (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tour_skip_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:alpha="0.55"
                android:background="?android:attr/selectableItemBackground"
                android:fontFamily="sans-serif"
                android:padding="4dp"
                android:text="@string/tour_btn_skip"
                android:textColor="?attr/primaryTextColor"
                android:textSize="13sp" />

            <!-- Dot indicators -->
            <LinearLayout
                android:id="@+id/tour_dots_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tour_next_btn"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="?attr/tourButtonBackground"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/tour_btn_next"
                android:textColor="?attr/tourButtonTextColor"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


