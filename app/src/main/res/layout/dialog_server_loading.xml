<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="36dp"
    android:paddingBottom="28dp"
    android:gravity="center_horizontal">

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/server_loading_spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorSize="56dp"
        app:trackThickness="4dp"
        android:layout_marginBottom="28dp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_server_loading_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/rpn_restore_dialog_title"
        android:textSize="17sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/primaryTextColor"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_server_loading_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/rpn_restore_dialog_status_unregistering"
        android:textSize="@dimen/default_font_text_view"
        android:textColor="?attr/primaryLightColorText"
        android:gravity="center"
        android:minLines="2"
        android:layout_marginBottom="28dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/server_loading_timeout_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:progress="0"
        app:trackCornerRadius="4dp"
        app:trackThickness="3dp"
        android:layout_marginBottom="20dp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_server_loading_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/rpn_restore_dialog_hint"
        android:textSize="@dimen/small_font_text_view"
        android:textColor="?attr/primaryLightColorText"
        android:alpha="0.55"
        android:gravity="center" />

</LinearLayout>
