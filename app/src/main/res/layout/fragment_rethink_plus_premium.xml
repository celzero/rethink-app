<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="visible"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="200dp">

            <LinearLayout
                android:id="@+id/hero_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_rethink_plus_sparkle"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.85" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/fhs_title_rethink"
                        style="@style/TextAppearance.Heading.HomeScreen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.85"
                        android:text="@string/rpn_title" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/fhs_title_rethink_desc"
                    style="@style/TextAppearance.SubHeading.HomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.55"
                    android:layout_marginTop="4dp"
                    android:text="@string/premium_subtitle" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/connection_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/accentBad"
                app:cardBackgroundColor="?attr/background"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/privacy_status_dot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/ic_circle"
                            android:backgroundTint="?attr/accentBad"
                            android:layout_marginEnd="10dp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/connection_ip"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text="2401:4900:cad3:ab93" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="21dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/connection_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/primaryLightColorText"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            tools:text="New Delhi, IN" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lbl_separator_dot"
                            android:textColor="?attr/primaryLightColorText"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp" />

                        <LinearLayout
                            android:id="@+id/isp_container"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/connection_isp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/primaryLightColorText"
                                android:textSize="12sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                tools:text="Bharti Airtel" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:padding="10dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/title1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unlimited Bandwidth"
                        android:drawablePadding="3dp"
                        android:textStyle="bold"
                        android:drawableStart="@drawable/dot_green"
                        android:layout_alignParentStart="true"
                        android:textSize="@dimen/large_font_text_view"
                        android:textColor="?attr/primaryTextColor"
                        android:layout_toStartOf="@id/img_1"
                        />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/sub_title1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No data limits"
                        android:layout_alignParentStart="true"
                        android:layout_below="@id/title1"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="@dimen/small_font_subheading_text"
                        android:layout_toStartOf="@id/img_1"
                        />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/img_1"
                        android:layout_width="wrap_content"
                        android:foregroundGravity="center_vertical"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_check_circle"
                        android:layout_alignParentEnd="true"
                        />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/title2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="More than 100 locations"
                        android:layout_alignParentStart="true"
                        android:drawablePadding="3dp"
                        android:drawableStart="@drawable/dot_green"
                        android:textSize="@dimen/large_font_text_view"
                        android:textColor="?attr/primaryTextColor"
                        android:layout_toStartOf="@id/img_2"
                        />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/sub_title2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Servers are in more than 100 cities."
                        android:layout_alignParentStart="true"
                        android:layout_below="@id/title2"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="@dimen/small_font_subheading_text"
                        android:layout_toStartOf="@id/img_2"
                        />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/img_2"
                        android:layout_width="wrap_content"
                        android:foregroundGravity="center_vertical"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_check_circle"
                        android:layout_alignParentEnd="true"
                        />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/title3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Map cities with app"
                        android:layout_alignParentStart="true"
                        android:textSize="@dimen/large_font_text_view"
                        android:textColor="?attr/primaryTextColor"
                        android:drawableStart="@drawable/dot_green"
                        android:drawablePadding="3dp"
                        android:layout_toStartOf="@id/img_3"
                        />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/sub_title3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forward app specific connections to different cities"
                        android:layout_alignParentStart="true"
                        android:layout_below="@id/title3"
                        android:textColor="?attr/primaryLightColorText"
                        android:textSize="@dimen/small_font_subheading_text"
                        android:layout_toStartOf="@id/img_3"
                        />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/img_3"
                        android:layout_width="wrap_content"
                        android:foregroundGravity="center_vertical"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_check_circle"
                        android:layout_alignParentEnd="true"
                        />

                </RelativeLayout>

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/plans_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/choose_plan"
                android:textColor="?attr/primaryTextColor"
                android:textSize="@dimen/extra_large_font_text_view"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="4dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/plans_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/choose_plan_subtitle"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="13sp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/extend_mode_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="?attr/accentGood"
                app:cardBackgroundColor="?attr/background"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_rethink_plus_sparkle"
                        android:tint="?attr/accentGood"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/extend_mode_banner_title"
                            android:textColor="?attr/accentGood"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_extend_mode_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/extend_mode_banner_desc"
                            android:textColor="?attr/primaryLightColorText"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.3" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/product_type_toggle"
                style="@style/toggleButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_subscription"
                    style="@style/toggleButtonNoStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/lbl_plan"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:cornerRadius="16dp"
                    android:layout_marginEnd="1dp"
                    app:checkedIcon="@null" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_one_time"
                    style="@style/toggleButtonNoStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/one_time_label"
                    android:layout_marginStart="1dp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:cornerRadius="16dp"
                    app:checkedIcon="@null" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/subscription_plans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/list_item_play_subs"
                tools:itemCount="2" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/cta_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="?attr/background"
        android:visibility="visible">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="?attr/divider"
            android:alpha="0.4" />

        <LinearLayout
            android:id="@+id/cta_inner_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="80dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subscribe_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/subscribe_now"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:iconTint="?attr/homeScreenHeaderTextColor"
                android:textColor="?attr/homeScreenHeaderTextColor"
                app:icon="@drawable/ic_rethink_plus_sparkle"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_contact_support"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:text="@string/contact_support_title"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:icon="@drawable/ic_rethink_plus"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:cornerRadius="22dp"
                app:strokeWidth="1dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/terms_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/rethink_terms"
                android:textAlignment="center"
                android:textColor="?attr/primaryLightColorText"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loading_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/background"
        android:visibility="gone">

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <include layout="@layout/shimmer_subscription_loading" />

        </com.facebook.shimmer.ShimmerFrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/error_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/background"
        android:padding="32dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/error_icon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/fingerprint_dialog_error"
            android:alpha="0.4"
            app:tint="?attr/secondaryTextColor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.32"
            app:layout_constraintBottom_toBottomOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/error_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/firewall_rule_block_app_exception"
            android:textAlignment="center"
            android:textColor="?attr/primaryTextColor"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/error_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/error_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/error_message"
            android:textAlignment="center"
            android:textColor="?attr/primaryLightColorText"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/error_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/retry_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:textColor="?attr/homeScreenHeaderTextColor"
            android:textSize="@dimen/large_font_text_view"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/error_message"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_contact_support_error"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_support_title"
            android:textAllCaps="false"
            android:layout_marginTop="10dp"
            android:textSize="14sp"
            app:cornerRadius="28dp"
            app:strokeWidth="1dp"
            app:icon="@drawable/ic_rethink_plus"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@id/retry_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
