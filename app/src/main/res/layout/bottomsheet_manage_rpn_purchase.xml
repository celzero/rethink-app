<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="60dp">

            <View
                android:id="@+id/drag_handle"
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_marginTop="12dp"
                android:background="?attr/border"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sub_details_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/divider"
                app:layout_constraintTop_toBottomOf="@id/drag_handle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="10dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_plan"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_sub_plan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Monthly" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="10dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_status"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_sub_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Active"
                            tools:textColor="?attr/primaryTextColor" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_sub_expiry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_expires_on"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_sub_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/primaryTextColor"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Jun 1, 2027" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/action_buttons_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/sub_details_card"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/cancel_subscription"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="?attr/primaryTextColor"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    app:strokeWidth="1.5dp"
                    app:icon="@drawable/ic_cross"
                    app:iconTint="?attr/primaryTextColor"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_revoke"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/revoke_subscription"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:strokeWidth="1.5dp"
                    android:textColor="?attr/primaryTextColor"
                    app:icon="@drawable/ic_info_white"
                    app:iconTint="?attr/primaryTextColor"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_resubscribe"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/resubscribe_title"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:textColor="?attr/primaryTextColor"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_refresh"
                    app:iconTint="?attr/primaryTextColor"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_resubscribe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorColor="?attr/accentGood"
                    app:trackColor="?attr/chipBgColorPositive"
                    tools:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_consume_purchase"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Consume purchase"
                    android:layout_marginTop="15dp"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    android:textColor="?attr/primaryTextColor"
                    app:icon="@drawable/ic_rethink_plus_sparkle"
                    app:iconTint="?attr/primaryTextColor"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    tools:visibility="visible" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cancel_note_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    tools:visibility="visible">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_cancel_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="@string/cancel_subscription_note"
                        android:textColor="?attr/primaryTextColor"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                </com.google.android.material.card.MaterialCardView>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_manage_subscription_on_google_play"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:visibility="visible"
                    android:text="@string/manage_on_google_play"
                    android:textColor="?attr/accentGood"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="300dp"
        android:visibility="gone"
        tools:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="28dp"
                android:paddingEnd="28dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progress_spinner"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:indeterminateTint="?attr/accentGood" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_loading_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/primaryTextColor"
                        tools:text="Cancelling subscription" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_loading_sub_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="13sp"
                    android:textColor="?attr/primaryLightColorText"
                    android:lineSpacingMultiplier="1.3"
                    tools:text="Please do not close the app" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="?attr/divider" />

                <LinearLayout
                    android:id="@+id/step_row_validating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_validating"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_validating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_validating"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_server"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_server"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_server"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_contacting_server"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_local"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_local"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_local"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_updating"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step_row_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/step_icon_refresh"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_tick"
                        android:tint="?attr/primaryLightColorText" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/step_label_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/progress_step_refreshing"
                        android:textSize="14sp"
                        android:textColor="?attr/primaryLightColorText" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</FrameLayout>

