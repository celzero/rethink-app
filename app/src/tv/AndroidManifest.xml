<?xml version="1.0" encoding="utf-8"?>
<!--
  rethink-tv fork (ezelab/rethink-tv): Android TV manifest additions.

  This manifest contributes a Leanback launcher activity for the `tv` flavor.
  It does not modify upstream activities declared in app/src/main/AndroidManifest.xml;
  Android TV launchers will surface only the activity with the LEANBACK_LAUNCHER
  intent filter.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android TV requires leanback support; touchscreens are explicitly optional
         so the app installs on TV devices that lack one. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:banner="@drawable/tv_banner"
        tools:replace="android:banner">

        <activity
            android:name="com.ezelab.rethinktv.RethinkTvLauncherActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>
